---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Image from '~/components/common/Image.astro';

interface Slide {
  title: string;
  description: string;
  image: {
    src: any;
    alt: string;
  };
}

interface Props {
  id?: string;
  tagline?: string;
  title?: string;
  subtitle?: string;
  slides: Slide[];
  isDark?: boolean;
}

const {
  id,
  tagline = 'La Ruta del Enigma',
  title = 'Los escenarios',
  subtitle = 'Sigue los pasos de Gregorio y Celina a través de algunos de los lugares más emblemáticos de Antigua Guatemala. Cada parada es una pieza de la historia. Cada rincón es una pista.',
  slides = [],
  isDark = false,
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass="max-w-6xl mx-auto">
  <Headline
    tagline={tagline}
    title={title}
    subtitle={subtitle}
    classes={{
      container: 'max-w-3xl sm:mx-auto',
      title: 'text-4xl md:text-5xl font-bold tracking-normal mb-4 font-heading',
      subtitle: 'max-w-3xl mx-auto sm:text-center text-xl text-muted dark:text-slate-400',
    }}
  />

  <section class="relative mx-auto mt-10 max-w-5xl" data-enigma-gallery>
    <div class="overflow-hidden rounded-2xl shadow-lg bg-white dark:bg-slate-900">
      <div class="flex transition-transform duration-500 ease-in-out" data-track>
        {
          slides.map((slide) => (
            <article class="min-w-full">
              <Image
                src={slide.image.src}
                alt={slide.image.alt}
                width={1200}
                height={675}
                widths={[400, 768, 1200]}
                sizes="(max-width: 768px) 100vw, 960px"
                layout="responsive"
                format="webp"
                class="h-full w-full object-cover"
              />

              <div class="p-6 md:p-8">
                <h3 class="font-heading text-2xl md:text-3xl font-bold tracking-normal dark:text-white">
                  {slide.title}
                </h3>
                <p class="mt-3 text-lg text-muted dark:text-slate-400">
                  {slide.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <button
      type="button"
      aria-label="Imagen anterior"
      class="absolute left-3 top-[38%] z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/70 text-slate-800 shadow-md backdrop-blur transition hover:bg-white dark:bg-slate-900/70 dark:text-white"
      data-prev
    >
      <Icon name="tabler:chevron-left" class="h-6 w-6" />
    </button>

    <button
      type="button"
      aria-label="Imagen siguiente"
      class="absolute right-3 top-[38%] z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/70 text-slate-800 shadow-md backdrop-blur transition hover:bg-white dark:bg-slate-900/70 dark:text-white"
      data-next
    >
      <Icon name="tabler:chevron-right" class="h-6 w-6" />
    </button>

    <div class="mt-6 flex justify-center gap-2" data-dots>
      {
        slides.map((_, index) => (
          <button
            type="button"
            aria-label={`Ir a imagen ${index + 1}`}
            class="h-2.5 w-2.5 rounded-full bg-slate-300 transition dark:bg-slate-600"
            data-dot
          />
        ))
      }
    </div>
  </section>
</WidgetWrapper>

<script>
  const galleries = document.querySelectorAll('[data-enigma-gallery]');

  galleries.forEach((gallery) => {
    const track = gallery.querySelector('[data-track]');
    const prev = gallery.querySelector('[data-prev]');
    const next = gallery.querySelector('[data-next]');
    const dots = Array.from(gallery.querySelectorAll('[data-dot]'));

    if (!track || !prev || !next || dots.length === 0) return;

    let current = 0;
    const total = dots.length;

    const updateGallery = () => {
      track.style.transform = `translateX(-${current * 100}%)`;

      dots.forEach((dot, index) => {
        dot.classList.toggle('bg-primary', index === current);
        dot.classList.toggle('bg-slate-300', index !== current);
        dot.classList.toggle('dark:bg-secondary', index === current);
        dot.classList.toggle('dark:bg-slate-600', index !== current);
      });
    };

    prev.addEventListener('click', () => {
      current = current === 0 ? total - 1 : current - 1;
      updateGallery();
    });

    next.addEventListener('click', () => {
      current = current === total - 1 ? 0 : current + 1;
      updateGallery();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        current = index;
        updateGallery();
      });
    });

    updateGallery();
  });
</script>