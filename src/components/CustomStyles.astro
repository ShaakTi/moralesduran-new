---
import '@fontsource-variable/inter';
import "@fontsource/cormorant-garamond";

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Cormorant Garamond';
    --aw-font-heading: 'Cormorant Garamond';

    --aw-color-primary: rgb(140 122 50);
    --aw-color-secondary: rgb(10 91 137);
    --aw-color-accent: rgb(205 187 116);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(244 240 231);

    --aw-color-bg-page-dark: rgb(39 35 28);

    ::selection {
      background-color: rgb(236 229 200);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Cormorant Garamond';
    --aw-font-heading: 'Cormorant Garamond';

    --aw-color-primary: rgb(140 122 50);
    --aw-color-secondary: rgb(10 91 137);
    --aw-color-accent: rgb(205 187 116);

    --aw-color-text-heading: rgb(244 240 231);
    --aw-color-text-default: rgb(230 223 206);
    --aw-color-text-muted: rgb(200 190 170);
    --aw-color-bg-page: rgb(39 35 28);
    --aw-color-bg-page-dark: rgb(25 22 18);

    ::selection {
      background-color: rgb(140 122 50);
      color: snow;
    }
  }
</style>