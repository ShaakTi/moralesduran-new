---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Mientras El Tiempo Se Detenga — Marco R. Morales',
  description: 'Ficción histórica ambientada en La Antigua Guatemala. Siglo XVIII, secretos coloniales, y un reloj que guarda el eco de historias jamás contadas.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Lee un fragmento ',
        href: '/descargas',
      },
      { text: 'Descubre la experiencia', href: '#experience' },
    ]}
    image={{ src: '~/assets/images/libros-MTD.png', alt: 'Mientras El Tiempo Se Detenga — portada del libro' }}
  >
    <Fragment slot="title">
      ¿Qué ocurriría si pudieras<br />
      <span class="text-accent dark:text-white">detener el tiempo?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Muchos concuerdan que pareciera que en la Antigua Guatemala, el tiempo pareciera haberse detenido. <strong>Mientras El Tiempo Se Detenga</strong> mezcla una hermosa historia de amor con misterio y ficción en una aventura donde el tiempo quizá no obedezca las reglas que conocemos.
    </Fragment>
  </Hero>

  <!-- Entra al universo ******************* -->

  <Features
    id="capitulos"
    tagline="Empieza aquí"
    title="Elige cómo entrar a la historia"
    subtitle="Entra al universo narrativo de Gregorio y Celina a través de estas experiencias. Cada una te ofrece una forma distinta de descubrir esta historia que cautivará tu corazón y tu imaginación."
    items={[
      {
        title: 'Leer la novela',
        description:
          'Descubre el misterio del reloj y los secretos ocultos durante siglos. Un artefacto que no solo mide las horas, sino que guarda el eco de historias jamás contadas.',
        icon: 'tabler:book',
      },
      {
        title: 'Vivir la experiencia',
        description:
          'Camina por las calles de La Antigua Guatemala y sigue las huellas de Gregorio. Cada rincón tiene una historia que contar.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Escuchar la canción',
        description:
          'Una hermosa pieza musical que captura la esencia de la historia. Inspirada en las palabras que Gregorio nunca olvidó',
        icon: 'tabler:music',
      },
      {
        title: 'Desbloquear contenido oculto',
        description:
          'Capítulos extra, escenas inéditas y secretos que solo los lectores más curiosos podrán descubrir. Avances de la secuela que ya se encuentra en desarrollo.',
        icon: 'tabler:key',
      },
    ]}
  />

  <!-- Libro **************** -->

  <Content
    isReversed
    tagline="La Novela"
    title="Mientras El Tiempo Se Detenga"
    items={[
      {
        title: 'Romance y misterio',
        description:
          'Una hermosa historia de amor que literalmente rompe las barreras del tiempo. Ambientada en la Antigua Guatemala del siglo XVIII, entenderás por qué el tiempo parece haberse detenido aquí.',
      },
      {
        title: 'Ficción histórica',
        description:
          'Siente cómo cambia tu percepción de la Antigua Guatemala mientras conoces personajes reales y ficticios en una trama que cautivará tu imaginación.',
      },
      {
        title: 'Un universo en expansión',
        description:
          'El libro ha inspirado música, una secuela y hasta un tour por las calles de Antigua Guatemala. Además de un capítulo extra exclusivo',
      },
    ]}
    image={{
      src: '~/assets/images/book-illustration.jpg',
      alt: 'Mientras El Tiempo Se Detenga — ilustración del libro',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">¿Qué ocurre cuando el tiempo deja de obedecer sus propias reglas?</h3>
      Te fascinará leer lo que el reloj del Arco de Santa Catalina tuvo el poder de hacer.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Celina's Enigma **************** -->

  <Content
    isAfterContent
    tagline="La Experiencia"
    title="Celina's Enigma"
    items={[
      {
        title: 'Camina dentro de la historia',
        description:
          'Lo que muchos describen como un tour literario, es en realidad toda una experiencia que confluye una historia de amor, misterio y ficción.',
      },
      {
        title: 'Una experiencia inolvidable',
        description:
          'Aun si no has leído el libro, este es un fascinante punto de partida para adentrarte en este universo narrativo. Y si ya lo leíste, será un regalo especial que conecta con la historia de la novela.',
      },
      {
        title: 'Resuelve el enigma',
        description:
          'Nunca volverás a ver La Antigua Guatemala con los mismos ojos. Prestarás atención a todos sus detalles y cada vez que vayas la experimentarás de forma distinta.',
      },
    ]}
    image={{
      src: '~/assets/images/celinas-enigma.jpg',
      alt: 'Tour narrativo por La Antigua Guatemala — Celina’s Enigma',
    }}
  >
    <Fragment slot="content">Un tour que recorre Antigua Guatemala siguiendo secretos ocultos entre conventos, fachadas y personajes que quizá nunca abandonaron la ciudad.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Extras **************** -->

  <Features
    id="extras"
    tagline="Contenido extra"
    title="La historia continúa"
    subtitle="<strong>Mientras El Tiempo Se Detenga</strong> ha dado lugar a una experiencia de muchos matices. Algunas de estas facetas están disponibles solamente para los lectores, otras para quienes quieran vivieron la experiencia de recorrer las calles de Antigua Guatemala siguiendo las huellas de Gregorio. Y otras más para cualquiera que desee explorar los obsequios que tenemos en nuestra sección de contenido extra."
    items={[
      {
        title: 'Capítulo extra exclusivo',
        description:
          'Disponible solamente para quienes han adquirido el libro. Se requerirá prueba de compra. Ten a la mano el código que viene incluido en tu copia física o en tu correo si compraste la versión digital.',
        icon: 'tabler:book',
      },
      {
        title: 'Avances de la secuela',
        description:
          '<strong>Mientras El Tiempo Se Detenga</strong> es solamente el inicio de una nueva aventura. El título, avances y otros detalles se compartirán exclusivamente con los lectores.',
        icon: 'tabler:scan-eye',
      },
      {
        title: 'La canción de Gregorio',
        description:
          'Esta hermosa melodía tenía que existir, aunque no fuera parte de la novela. Disponible para cualquiera que quiera escucharla, pero con algunos detalles disponibles solamente para los lectores. Inspirada en las palabras que Gregorio nunca olvidó.',
        icon: 'tabler:music',
      },
      {
        title: 'Merchandising exclusivo',
        description:
          'Todos los souvenirs, recuerdos y objetos que se ofrecen durante la gira <strong>Celina’s Enigma</strong> también pueden conseguirse aquí. Artículos que son un pedacito de esta historia que querrás llevar contigo.',
        icon: 'tabler:paper-bag',
      },
    ]}
  />

  <!-- Sobre el autor **************** -->

  <Content
    isReversed
    tagline="Autor"
    title="Marco R. Morales"
    image={{
      src: '~/assets/images/myPortrait.jpg',
      alt: 'Marco R. Morales — autor de Mientras El Tiempo Se Detenga',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Sobre el autor</h3>
      <p><strong>Marco R. Morales</strong> es escritor, diseñador gráfico y docente de inglés. Nació en El Salvador y vive en Guatemala, donde pasa buena parte del tiempo alternando entre proyectos creativos, enseñanza y nuevas ideas que suelen aparecer en momentos poco convenientes.</p>
      <p><strong>Mientras El Tiempo Se Detenga</strong> surgió de una pregunta sencilla: ¿por qué parece que el tiempo se ha detenido en Antigua? Lo que comenzó como una idea terminó convirtiéndose en el universo que aún está creciendo.</p>
      <p>Aunque su trabajo principal ha estado ligado durante años a la enseñanza del inglés y al diseño, también ha desarrollado aplicaciones móviles, creado ilustraciones y explorado distintas formas de contar historias. Prefiere pensar que la creatividad rara vez se queda dentro de una sola profesión.</p>
      <p>No suele considerarse una figura pública ni alguien especialmente interesado en construir una imagen de autor. Le atraen más las historias, el cyberpunk (!) y las preguntas difíciles: esas que aparecen tarde por la noche y ya no dejan dormir.</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>


  <!-- Precios ******************* -->

  <Pricing
    id="precio"
    title="Elige tu formato"
    subtitle="Compra directamente aquí a mejor precio que en cualquier otra plataforma."
    prices={[
      {
        title: 'E-Book',
        subtitle: 'ePub, AZW3 o PDF — entrega inmediata',
        price: '10.35',
        period: 'USD',
        items: [
          { description: 'Formato ePub (Kindle, Apple Books)' },
          { description: 'Formato AZW3' },
          { description: 'Formato PDF' },
          { description: 'Capítulo extra exclusivo incluido' },
        ],
        callToAction: {
          text: 'Comprar E-Book',
          href: '#',
        },
      },
      {
        title: 'Copia Física — Guatemala',
        subtitle: 'Envío por courier',
        price: '160',
        period: 'GTQ',
        items: [
          { description: 'Entrega de 2 a 4 días hábiles' },
          { description: 'Envío por courier en Guatemala' },
          { description: 'Pago por transferencia Banco Industrial' },
          { description: 'Capítulo extra exclusivo incluido' },
        ],
        callToAction: {
          text: 'Comprar en Guatemala',
          href: 'https://wa.me/50252803506',
          target: '_blank',
        },
        hasRibbon: true,
        ribbonTitle: 'Popular',
      },
      {
        title: 'Copia Física — EE.UU.',
        subtitle: 'Envío desde Lulu.com',
        price: '20.50',
        period: 'USD',
        items: [
          { description: 'Impresión y envío desde Lulu.com' },
          { description: 'Dos semanas de margen de entrega' },
          { description: 'Envío a cualquier dirección en EE.UU.' },
          { description: 'Capítulo extra exclusivo incluido' },
        ],
        callToAction: {
          text: 'Comprar en EE.UU.',
          href: '#',
        },
      },
    ]}
  />

  <!-- Testimonios ******************* -->

  <Testimonials
    title="Esto dicen lectores como tú"
    subtitle="Comparte tu experiencia en redes sociales o escríbeme directamente. Tus comentarios son muy importantes."
    testimonials={[
      {
        testimonial:
          'Caminar en las calles de la ciudad colonial ahora, después de haber leído el libro, es toda una exquisitez. No puedo dejar de imaginarme a mí mismo en el pasado mientras contemplo las iglesias, los conventos y por supuesto, el Arco.',
        name: 'Omar F.',
      },
      {
        testimonial:
          'Sus enigmáticas alusiones a detalles arquitectónicos y artísticos de la que llegara a ser una mítica ciudad del recuerdo, y sus emocionantes escenas de acción y suspenso mantienen al lector absorto en el desenvolvimiento de los hechos y enamorado de los pintorescos personajes.',
        name: 'Judah-Ben M.',
      },
      {
        testimonial:
          'Te sumerges tanto en la lectura que olvidas que no es real. El final ni lo cuento, pero valió la pena cada página. Tiene suspenso, risa, amor y drama.',
        name: 'Daniela M.',
      },
      {
        testimonial:
          'La próxima vez que vaya a La Antigua la voy a ver con unos ojos totalmente distintos. Es una historia que me ha cautivado, por lo que recomiendo mucho este libro.',
        name: 'Mafer R.',
      },
    ]}
  />

  <!-- Call to Action ******************* -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Comenzar la experiencia',
        href: '#precio',
        icon: 'tabler:backpack',
      },
    ]}
  >
    <Fragment slot="title">
     La historia no termina<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap"> al cerrar el libro.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Si has llegado hasta aquí, es momento que permitas que esta historia te cautive. Elige tu formato, o haz la reservación para el Enigma de Celina. No importa la ruta que elijas. Estás a mitad de camino.
    </Fragment>
  </CallToAction>

</Layout>